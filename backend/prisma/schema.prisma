datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

enum Role {
  ADMIN
  USER
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password String
  crm     String?
  name          String
  role          Role      
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())

}

model Patient {
  id                     Int      @id @default(autoincrement())
  name                   String
  cpf                    String   @unique
  birth_date             DateTime
  is_active              Boolean  @default(true)
  created_at             DateTime @default(now())

  // Features Clínicas base
  gestacoes              Float?
  glicemia               Float
  pressao                Float
  espessura_pele         Float?
  insulina               Float?
  imc                    Float
  historico_familiar     Float?
  idade                  Float

  // Resultados da Predição (podem ser nulos até a predição rodar)
  predicao_probabilidade Float?
  predicao_risco         String?  // Ex: "ALTO", "MODERADO", "BAIXO"
  predicao_data          DateTime?
}