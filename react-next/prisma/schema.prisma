datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
}

enum Sexo {
  MASCULINO
  FEMININO
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String
  crm        String?
  name       String
  role       Role      @default(USER)
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  patients   Patient[]
}

model Patient {
  id            Int            @id @default(autoincrement())
  user_id       Int
  user          User           @relation(fields: [user_id], references: [id])
  name          String
  sexo          Sexo
  birth_date    DateTime
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  examResults   ExamResult[]

  @@index([user_id])
}

model ExamResult {
  id            Int      @id @default(autoincrement())
  patient_id    Int
  patient       Patient  @relation(fields: [patient_id], references: [id])
  exam_date     DateTime
  created_at    DateTime @default(now())
  source_lab    String?        // "Fleury", "DASA", manual
  source_type   String         // "pdf" | "image" | "manual"
  exam_category String         // "hemograma" | "bioquimica" | "lipidios" | "renal" | etc.
  values        Json           // { "hemoglobina": 12.5, "hematocrito": 38.2, ... }
  raw_ocr_text  String?        // texto bruto extraído pelo Claude (auditoria)

  @@index([patient_id, exam_date])
  @@index([patient_id, exam_category])
}
