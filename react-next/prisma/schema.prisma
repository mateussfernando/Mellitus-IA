datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String
  crm        String?
  name       String
  role       Role     @default(USER)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
}

// Dados anonimizados coletados para re-treino do modelo (sem nenhum identificador)
model TrainingData {
  id                     Int      @id @default(autoincrement())
  created_at             DateTime @default(now())

  gestacoes              Float?
  glicemia               Float
  pressao                Float
  espessura_pele         Float?
  insulina               Float?
  imc                    Float
  historico_familiar     Float?
  idade                  Float

  predicao_probabilidade Float?
  predicao_risco         String?
}

model Patient {
  id                     Int       @id @default(autoincrement())
  name                   String
  cpf                    String    @unique
  birth_date             DateTime
  is_active              Boolean   @default(true)
  created_at             DateTime  @default(now())

  gestacoes              Float?
  glicemia               Float
  pressao                Float
  espessura_pele         Float?
  insulina               Float?
  imc                    Float
  historico_familiar     Float?
  idade                  Float

  predicao_probabilidade Float?
  predicao_risco         String?
  predicao_data          DateTime?
}
